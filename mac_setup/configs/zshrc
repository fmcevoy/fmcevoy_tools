# ---------------------------------------------------------------------------
# Preexec hook: show expanded alias before every command
# ---------------------------------------------------------------------------
_expand_alias_preexec() {
  local cmd="${1%% *}"
  local expanded="${aliases[$cmd]:-}"
  if [[ -n "$expanded" ]]; then
    printf '\033[2m→ %s\033[0m\n' "${1/$cmd/$expanded}"
  fi
}

autoload -Uz add-zsh-hook
add-zsh-hook preexec _expand_alias_preexec


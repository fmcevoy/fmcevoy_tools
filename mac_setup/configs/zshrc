# Git: stash, update main, rebase current branch
prr() {
  local stashed=false
  if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
    git stash push -m "prr-auto" && stashed=true
  fi
  git checkout main &&
    git pull --rebase &&
    git checkout - &&
    git rebase main -Xtheirs
  $stashed && git stash pop
}

# ---------------------------------------------------------------------------
# Poetry helpers
# ---------------------------------------------------------------------------
alias penv='poetry env use $(which python)'
alias psh='poetry shell'
alias pn='poetry update && poetry install'

activate() {
  local venv_path
  venv_path="$(poetry env info --path 2>/dev/null)"
  if [[ -n "$venv_path" && -f "$venv_path/bin/activate" ]]; then
    source "$venv_path/bin/activate"
  else
    # Fallback to local env directory
    if [[ -f env/bin/activate ]]; then
      source env/bin/activate
    else
      echo "No virtualenv found"
    fi
  fi
}

# ---------------------------------------------------------------------------
# Fuzzy git diff functions
# ---------------------------------------------------------------------------
# fzf + delta: interactive file picker with syntax-highlighted diff preview
fd() {
  local file
  file=$( (git diff --name-only HEAD 2>/dev/null; git diff --name-only 2>/dev/null; git diff --cached --name-only 2>/dev/null) | sort -u | fzf --preview 'git diff HEAD -- {} | delta --width=${FZF_PREVIEW_COLUMNS:-80}' --preview-window=right:65%)
  [[ -n "$file" ]] && git diff HEAD -- "$file" | delta
}

# fzf + difftastic: interactive file picker with structural diff preview
fdd() {
  local file
  file=$( (git diff --name-only HEAD 2>/dev/null; git diff --name-only 2>/dev/null; git diff --cached --name-only 2>/dev/null) | sort -u | fzf --preview 'difft <(git show HEAD:{}) {}' --preview-window=right:65%)
  [[ -n "$file" ]] && difft <(git show HEAD:"$file") "$file"
}


if [[ -d "$GRAPHVIZ_PREFIX" ]]; then
  export CFLAGS="-I${GRAPHVIZ_PREFIX}/include"
  export LDFLAGS="-L${GRAPHVIZ_PREFIX}/lib"
fi

# ---------------------------------------------------------------------------
# Oh My Zsh
# ---------------------------------------------------------------------------
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME=""

plugins=(
  git
  fzf
  fzf-tab
  docker
  kubectl
  golang
  terraform
  zsh-autosuggestions
  zsh-syntax-highlighting
)

[[ -d "$ZSH" ]] && source "$ZSH/oh-my-zsh.sh"

# ---------------------------------------------------------------------------
# Tool initializations (order matters)
# ---------------------------------------------------------------------------
# mise (runtime version manager)
command -v mise &>/dev/null && eval "$(mise activate zsh)"

# pyenv
if [[ -d "$HOME/.pyenv" ]]; then
  export PYENV_ROOT="$HOME/.pyenv"
  eval "$(pyenv init -)"
  eval "$(pyenv virtualenv-init -)"
fi

# zoxide (smart cd)
command -v zoxide &>/dev/null && eval "$(zoxide init zsh)"

# temporal completion (conditional)
command -v temporal &>/dev/null && eval "$(temporal completion zsh)" 2>/dev/null

# Custom completions (claude, cursor, opencode, meldr, etc.)
[[ -f "$HOME/.completions.zsh" ]] && source "$HOME/.completions.zsh"

# carapace (universal shell completions for 800+ CLIs)
if command -v carapace &>/dev/null; then
  export CARAPACE_BRIDGES='zsh,fish,bash,inshellisense'
  zstyle ':completion:*' format $'\e[2;37mCompleting %d\e[m'
  local _carapace_cache="$HOME/.cache/carapace/init.zsh"
  local _carapace_bin="$(command -v carapace)"
  if [[ ! -f "$_carapace_cache" || "$_carapace_bin" -nt "$_carapace_cache" ]]; then
    mkdir -p "${_carapace_cache:h}"
    carapace _carapace zsh > "$_carapace_cache" 2>/dev/null
  fi
  source "$_carapace_cache"
fi

# starship prompt (MUST be last — installs precmd hook)
command -v starship &>/dev/null && eval "$(starship init zsh)"


#!/usr/bin/env bash
# =============================================================================
# tmux_help - Colored command reference card
# =============================================================================

RST='\033[0m'
BLD='\033[1m'
DIM='\033[2m'
CYN='\033[36m'
YEL='\033[33m'
GRN='\033[32m'
MAG='\033[35m'
WHT='\033[1;37m'

echo ""
echo -e "${BLD}${CYN}╭──────────────────────────────────────────────╮${RST}"
echo -e "${BLD}${CYN}│          Command Reference Card               │${RST}"
echo -e "${BLD}${CYN}╰──────────────────────────────────────────────╯${RST}"

echo ""
echo -e "${BLD}${YEL}  Tmux${RST}"
echo -e "  ${GRN}Ctrl-a |${RST}       ${DIM}Vertical split${RST}"
echo -e "  ${GRN}Ctrl-a -${RST}       ${DIM}Horizontal split${RST}"
echo -e "  ${GRN}Alt-Arrow${RST}      ${DIM}Switch pane${RST}"
echo -e "  ${GRN}Ctrl-a c${RST}       ${DIM}New window${RST}"
echo -e "  ${GRN}Ctrl-a r${RST}       ${DIM}Reload tmux config${RST}"
echo -e "  ${GRN}Ctrl-a S-Left${RST}  ${DIM}Move window left${RST}"
echo -e "  ${GRN}Ctrl-a S-Right${RST} ${DIM}Move window right${RST}"
echo -e "  ${GRN}Ctrl-a F${RST}       ${DIM}tmux-fzf${RST}"
echo -e "  ${GRN}Ctrl-a Tab${RST}     ${DIM}Extrakto (copy text from pane)${RST}"
echo -e "  ${GRN}t${RST}              ${DIM}Start/attach Dev session${RST}"
echo -e "  ${GRN}tx${RST}             ${DIM}Kill all tmux sessions${RST}"
echo -e "  ${GRN}tl${RST}             ${DIM}List tmux sessions${RST}"

echo ""
echo -e "${BLD}${YEL}  Meldr (multi-repo workspaces)${RST}"
echo -e "  ${GRN}meldr create <name> -r <url> -b <branch>${RST}"
echo -e "  ${DIM}                   Init workspace + worktrees${RST}"
echo -e "  ${GRN}meldr wt add <branch>${RST}  ${DIM}Create worktrees for all packages${RST}"
echo -e "  ${GRN}meldr wt remove <branch>${RST} ${DIM}Remove worktrees${RST}"
echo -e "  ${GRN}meldr wt list${RST}      ${DIM}List active worktrees${RST}"
echo -e "  ${GRN}meldr status${RST}       ${DIM}Workspace dashboard${RST}"
echo -e "  ${GRN}meldr sync${RST}         ${DIM}Sync with upstream (rebase)${RST}"
echo -e "  ${GRN}meldr exec <cmd>${RST}   ${DIM}Run command in all packages${RST}"

echo ""
echo -e "${BLD}${YEL}  CLI Aliases${RST}"
echo -e "  ${GRN}ls${RST}  ${DIM}→ eza -al${RST}    ${GRN}cat${RST} ${DIM}→ bat${RST}       ${GRN}vim${RST} ${DIM}→ nvim${RST}"
echo -e "  ${GRN}du${RST}  ${DIM}→ duf${RST}        ${GRN}dig${RST} ${DIM}→ doggo${RST}    ${GRN}ack${RST} ${DIM}→ ag${RST}"

echo ""
echo -e "${BLD}${YEL}  Shortcuts${RST}"
echo -e "  ${GRN}v${RST}              ${DIM}Edit ~/.zshrc in nvim${RST}"
echo -e "  ${GRN}vo${RST}             ${DIM}View ~/.zshrc${RST}"
echo -e "  ${GRN}r${RST}              ${DIM}Reload shell (source ~/.zshrc)${RST}"
echo -e "  ${GRN}k${RST}              ${DIM}kubectl${RST}"
echo -e "  ${GRN}kc${RST}             ${DIM}kubectl current-context${RST}"
echo -e "  ${GRN}a / ac${RST}         ${DIM}AWS assume role / console${RST}"
echo -e "  ${GRN}dx${RST}             ${DIM}Docker kill all containers${RST}"
echo -e "  ${GRN}routes${RST}         ${DIM}Show routing table${RST}"
echo -e "  ${GRN}prr${RST}            ${DIM}Stash, rebase main, restore${RST}"
echo -e "  ${GRN}fd${RST}             ${DIM}Fuzzy git diff (delta)${RST}"
echo -e "  ${GRN}fdd${RST}            ${DIM}Fuzzy git diff (difftastic)${RST}"
echo -e "  ${GRN}h${RST}              ${DIM}Show this help card${RST}"
echo -e "  ${GRN}m / medlr${RST}      ${DIM}meldr (typo-friendly aliases)${RST}"
echo -e "  ${GRN}ch${RST}             ${DIM}Headless cursor (streaming)${RST}"
echo -e "  ${GRN}cch${RST}            ${DIM}Headless claude${RST}"
echo -e "  ${GRN}gch${RST}            ${DIM}Headless gemini${RST}"
echo -e "  ${GRN}xch${RST}            ${DIM}Headless codex${RST}"
echo -e "  ${GRN}pch${RST}            ${DIM}Headless pi${RST}"
echo -e "  ${GRN}kch${RST}            ${DIM}Headless kiro${RST}"

echo ""
echo -e "${BLD}${YEL}  Neovim${RST}"
echo -e "  ${GRN}Leader-p${RST}       ${DIM}Find files${RST}"
echo -e "  ${GRN}Leader-fg${RST}      ${DIM}Live grep${RST}"
echo -e "  ${GRN}Leader-fb${RST}      ${DIM}Buffers${RST}"
echo -e "  ${GRN}Leader-s${RST}       ${DIM}Save all${RST}"
echo -e "  ${GRN}Ctrl-n${RST}         ${DIM}NERDTree${RST}"
echo -e "  ${GRN}Ctrl-\\${RST}        ${DIM}Terminal${RST}"
echo -e "  ${GRN}jj${RST}             ${DIM}Escape + save${RST}"

echo ""
echo -e "${BLD}${YEL}  Claude Code MCP Servers${RST}"
echo -e "  ${GRN}context7${RST}       ${DIM}Up-to-date library docs${RST}"
echo -e "  ${GRN}playwright${RST}     ${DIM}Browser automation & testing${RST}"
echo -e "  ${GRN}github${RST}         ${DIM}PRs, issues, code search${RST}"
echo -e "  ${GRN}supabase${RST}       ${DIM}Database & API (needs token)${RST}"
echo -e "  ${GRN}aws-cdk${RST}        ${DIM}CDK guidance & nag rules${RST}"
echo -e "  ${GRN}docker${RST}         ${DIM}Container management${RST}"
echo -e "  ${GRN}fly${RST}            ${DIM}Deploy & manage Fly.io apps${RST}"
echo -e "  ${GRN}gcloud${RST}         ${DIM}Google Cloud${RST}"
echo -e "  ${GRN}seq-thinking${RST}   ${DIM}Structured problem solving${RST}"

echo ""
echo -e "${BLD}${YEL}  Poetry${RST}"
echo -e "  ${GRN}penv${RST}           ${DIM}poetry env use \$(which python)${RST}"
echo -e "  ${GRN}psh${RST}            ${DIM}poetry shell${RST}"
echo -e "  ${GRN}pn${RST}             ${DIM}poetry update + install${RST}"
echo -e "  ${GRN}activate${RST}       ${DIM}source env/bin/activate${RST}"

echo ""

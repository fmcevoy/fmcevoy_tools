#!/usr/bin/env zsh
# =============================================================================
# start_tmux_dev - Dev session launcher
# =============================================================================
# Creates a "Dev" tmux session with an apps tab and auto-opens meldr worktrees.
# Usage: ~/start_tmux_dev (aliased as 't' in zshrc)

SESSION="Dev"

# Attach if session already exists
if tmux has-session -t "$SESSION" 2>/dev/null; then
  exec tmux attach-session -t "$SESSION"
fi

# Get terminal dimensions for percentage-based splits
COLS="$(tput cols)"
LINES="$(tput lines)"

# Create session (detached so we can configure before attaching)
tmux new-session -d -s "$SESSION" -x "$COLS" -y "$LINES"

# Export TMUX so meldr detects a tmux context when recreating worktree windows.
# Without this, `meldr worktree open` fails with NotInTmux because the script
# runs outside any tmux client.
export TMUX=$(tmux display-message -t "${SESSION}" -p '#{socket_path},#{pid},0')

# ---------------------------------------------------------------------------
# Tab 0: apps (8 panes — 2 columns x 4 rows)
# ---------------------------------------------------------------------------
tmux rename-window -t "${SESSION}:0" "apps"

# Create 7 additional panes (8 total), then tile them
for i in {1..7}; do
  tmux split-window -t "${SESSION}:apps"
done
tmux select-layout -t "${SESSION}:apps" tiled

# Select first pane
tmux select-pane -t "${SESSION}:apps.0"

# ---------------------------------------------------------------------------
# Auto-open meldr worktrees across all workspaces
# ---------------------------------------------------------------------------
if command -v meldr &>/dev/null; then
  for ws_dir in ~/workspaces/ws-*/; do
    [[ -f "$ws_dir/meldr.toml" ]] || continue

    # Get list of worktree branches
    branches=("${(@f)$(cd "$ws_dir" && meldr worktree list 2>/dev/null | sed 's/ *(tmux:.*//' | tr -d ' ')}")

    for branch in "${branches[@]}"; do
      [[ -z "$branch" ]] && continue
      # Open tmux tabs for this worktree (meldr handles the layout)
      (cd "$ws_dir" && meldr worktree open "$branch" 2>/dev/null) &
    done
  done
  wait
fi

# Select first window and attach
tmux select-window -t "${SESSION}:0"
exec tmux attach-session -t "$SESSION"
